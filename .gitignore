# Arduino / ESP32 build outputs
build/
build-*/
*.bin
*.elf
*.hex
*.map
*.eep
*.lst
*.sym
*.o
*.a
*.d
*.ii
*.s
*.bootloader.bin
*.partitions.bin
*.merged.bin
*.uf2

# Arduino IDE / CLI local files
*.ino.cpp
arduino-cli.yaml
.arduinoIDE/

# PlatformIO local files, if someone chooses to use it later
.pio/
.piolibdeps/
.libdeps/

# Editor and OS files
.vscode/
.idea/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
venv/
.venv/
*.swp
*.tmp
*.bak
.DS_Store
Thumbs.db

# UI runtime telemetry logs. The app recreates these locally.
UI/data/live/*.csv
UI/data/archive/

# Local collaborator/reference sketches kept for comparison, not publishing.
*Reference*/

# This branch publishes the real-temperature firmware. Simulated-temperature
# sensor sketches live on the main branch.
ESP_Mesh_BME280DataSim/
ESP_Mesh_DHT11DataSim/
ESP_Mesh_DHT22DataSim/

# Optional local overrides. The committed Config.h files contain public defaults.
Config.local.h

# Keep only this project's shared local code in libraries/. External Arduino
# dependencies should be installed through Arduino IDE or GitHub Actions.
libraries/*
!libraries/MeshDebug/
!libraries/MeshDebug/**
!libraries/MeshRouting/
!libraries/MeshRouting/**
